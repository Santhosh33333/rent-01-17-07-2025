generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String    @unique
  passwordHash      String
  fullName          String
  dateOfBirth       DateTime
  gender            String    @default("OTHER")
  avatarUrl         String?
  bio               String?
  city              String?
  country           String?
  status            String    @default("ACTIVE")
  role              String    @default("USER")
  emailVerified     Boolean   @default(false)
  mobileVerified    Boolean   @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  verification      Verification?
  walkingPartner    WalkingPartner?
  wallet            Wallet?
  loginHistory      LoginHistory[]
  devices           Device[]
  sessions          Session[]
  notifications     Notification[]
  trustScore        TrustScore?
  referredBy        Referral?      @relation("ReferredBy")
  referrals         Referral[]     @relation("ReferralSender")

  walkingRequests   WalkingRequest[]         @relation("WalkingRequestRequester")
  acceptedWalks     WalkingRequest[]         @relation("WalkAcceptedBy")
  completedWalks    WalkingRequest[]         @relation("WalkCompletedBy")
  transactions      Transaction[]
  communities       CommunityMember[]        @relation("CommunityMembership")
  ownedCommunities  Community[]              @relation("CommunityOwner")
  events            Event[]                  @relation("EventOrganizer")
  eventAttendances  EventAttendee[]          @relation("EventAttendeeUser")
  sentMessages      Message[]                @relation("MessageSender")
  receivedMessages  Message[]                @relation("MessageReceiver")
  reportsFiled      Report[]                 @relation("ReportFiledBy")
  reportsAgainst    Report[]                 @relation("ReportAgainst")
  ratingsGiven      Rating[]                 @relation("RatingGivenBy")
  ratingsReceived   Rating[]                 @relation("RatingReceivedBy")
  sosAlerts         SosAlert[]
  blocksInitiated   UserBlock[]              @relation("BlockInitiator")
  blocksReceived    UserBlock[]              @relation("BlockTarget")
  locationShares    LocationShare[]
  auditLogs         AuditLog[]
  withdrawalRequests WithdrawalRequest[]
  adminProfile       AdminUser?

  @@index([status])
  @@index([role])
  @@index([city])
}

model Verification {
  id                 String   @id @default(uuid())
  userId             String   @unique
  selfieUrl          String?
  govIdUrl           String?
  govIdType          String?
  addressProofUrl    String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  emergencyContactRelation String?
  status             String   @default("UNVERIFIED")
  reviewedBy         String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  history            VerificationHistory[]

  @@index([status])
}

model VerificationHistory {
  id             String   @id @default(uuid())
  verificationId String
  status         String
  note           String?
  changedBy      String?
  createdAt      DateTime @default(now())

  verification   Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
}

model WalkingPartner {
  id                  String   @id @default(uuid())
  userId              String   @unique
  status              String   @default("NONE")
  rating              Float    @default(0)
  totalWalks          Int      @default(0)
  totalEarnings       Float    @default(0)
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  upiId               String?
  reviewedBy          String?
  reviewedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications        WalkingRequestApplication[]

  @@index([status])
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Float    @default(0)
  currency      String   @default("INR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  withdrawals   WithdrawalRequest[]
}

model Transaction {
  id            String   @id @default(uuid())
  walletId      String
  userId        String
  type          String
  status        String   @default("COMPLETED")
  amount        Float
  description   String?
  referenceId   String?
  createdAt     DateTime @default(now())

  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id            String   @id @default(uuid())
  userId        String
  walletId      String
  amount        Float
  status        String   @default("PENDING")
  method        String
  accountDetail String?
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([status])
}

model WalkingRequest {
  id              String   @id @default(uuid())
  requesterId     String
  acceptedById    String?
  status          String   @default("OPEN")
  startLocation   String
  endLocation     String
  startTime       DateTime
  durationMinutes Int?
  notes           String?
  fare            Float?
  completedById   String?
  completedAt     DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester       User     @relation("WalkingRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  acceptedBy      User?    @relation("WalkAcceptedBy", fields: [acceptedById], references: [id])
  completedBy     User?    @relation("WalkCompletedBy", fields: [completedById], references: [id])
  applications    WalkingRequestApplication[]

  @@index([status])
  @@index([requesterId])
}

model WalkingRequestApplication {
  id            String   @id @default(uuid())
  requestId     String
  applicantId   String
  status        String   @default("PENDING")
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request       WalkingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  applicant     WalkingPartner @relation(fields: [applicantId], references: [userId], onDelete: Cascade)

  @@unique([requestId, applicantId])
  @@index([requestId])
}

model Community {
  id            String   @id @default(uuid())
  name          String
  description   String?
  avatarUrl     String?
  privacy       String   @default("PUBLIC")
  ownerId       String
  city          String?
  memberCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User             @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       CommunityMember[]

  @@index([privacy])
  @@index([city])
}

model CommunityMember {
  id          String   @id @default(uuid())
  communityId String
  userId      String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation("CommunityMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String?
  organizerId   String
  communityId   String?
  location      String?
  startTime     DateTime
  endTime       DateTime?
  capacity      Int?
  attendeeCount Int      @default(0)
  status        String   @default("PUBLISHED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizer     User         @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees     EventAttendee[]

  @@index([organizerId])
}

model EventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("REGISTERED")
  checkedInAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation("EventAttendeeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

model Message {
  id             String   @id @default(uuid())
  senderId       String
  receiverId     String
  conversationId String
  content        String
  status         String   @default("SENT")
  readAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sender         User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId, receiverId])
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String   @default("PENDING")
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User     @relation("ReportFiledBy", fields: [reporterId], references: [id], onDelete: Cascade)
  target      User     @relation("ReportAgainst", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Rating {
  id          String   @id @default(uuid())
  raterId     String
  ratedId     String
  targetType  String
  ratingType  String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())

  rater       User     @relation("RatingGivenBy", fields: [raterId], references: [id], onDelete: Cascade)
  rated       User     @relation("RatingReceivedBy", fields: [ratedId], references: [id], onDelete: Cascade)

  @@index([ratedId])
}

model SosAlert {
  id          String   @id @default(uuid())
  userId      String
  latitude    Float?
  longitude   Float?
  message     String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorType   String
  action      String
  entityType  String?
  entityId    String?
  metadata    String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  loggedInAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  deviceType   String
  deviceToken  String?
  fcmToken     String?
  name         String?
  lastActiveAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserBlock {
  id          String   @id @default(uuid())
  blockerId   String
  blockedId   String
  reason      String?
  createdAt   DateTime @default(now())

  blocker     User     @relation("BlockInitiator", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User     @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model TrustScore {
  id          String   @id @default(uuid())
  userId      String   @unique
  score       Int      @default(0)
  factors     String?
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LocationShare {
  id          String   @id @default(uuid())
  sharerId    String
  viewerId    String
  latitude    Float
  longitude   Float
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  sharer      User     @relation(fields: [sharerId], references: [id], onDelete: Cascade)

  @@index([sharerId])
}

model Referral {
  id           String   @id @default(uuid())
  referrerId   String
  referredId   String   @unique
  code         String
  rewardClaimed Boolean @default(false)
  createdAt    DateTime @default(now())

  referrer     User     @relation("ReferralSender", fields: [referrerId], references: [id], onDelete: Cascade)
  referred     User     @relation("ReferredBy", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// ============================================================
// ADMIN CONSOLE 2026 - EXTENDED MODELS
// ============================================================

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  permissions String   // JSON array of permission keys
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins      AdminUser[]
}

model AdminUser {
  id              String   @id @default(uuid())
  userId          String   @unique
  roleId          String
  department      String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  lastActiveAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            AdminRole @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions        AdminSession[]
  loginAttempts   AdminLoginAttempt[]
  notifications   AdminNotification[]

  @@index([roleId])
}

model AdminSession {
  id           String   @id @default(uuid())
  adminUserId  String
  sessionToken String   @unique
  ipAddress    String?
  userAgent    String?
  location     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model AdminLoginAttempt {
  id           String   @id @default(uuid())
  adminUserId  String?
  email        String
  ipAddress    String?
  userAgent    String?
  success      Boolean
  failureReason String?
  createdAt    DateTime @default(now())

  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
}

model AdminNotification {
  id          String   @id @default(uuid())
  adminUserId String
  type        String
  title       String
  body        String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, isRead])
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  title       String
  body        String
  category    String
  variables   String?  // JSON array of variable names
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BroadcastCampaign {
  id            String   @id @default(uuid())
  name          String
  channel       String   // PUSH, EMAIL, SMS, IN_APP
  audience      String   // JSON filter criteria
  title         String
  body          String
  status        String   @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, CANCELLED
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalTargeted Int      @default(0)
  totalSent     Int      @default(0)
  totalDelivered Int     @default(0)
  totalOpened   Int      @default(0)
  totalClicked  Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  position    String   @default("HOME_TOP") // HOME_TOP, HOME_MID, WALKS, COMMUNITIES, EVENTS
  targetAudience String @default("ALL") // ALL, USERS, PARTNERS, NEW_USERS
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  priority    Int      @default(0)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id              String   @id @default(uuid())
  key             String   @unique
  value           String
  category        String
  description     String?
  dataType        String   @default("STRING") // STRING, NUMBER, BOOLEAN, JSON
  isPublic        Boolean  @default(false)
  updatedBy       String?
  updatedAt       DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(false)
  rolloutPercentage Int @default(0)
  targetRoles String?  // JSON array of roles
  targetCities String? // JSON array of cities
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

model ContentArticle {
  id          String   @id @default(uuid())
  type        String   // FAQ, HELP, TERMS, PRIVACY, POLICY, ANNOUNCEMENT
  title       String
  slug        String   @unique
  body        String
  excerpt     String?
  tags        String?  // JSON array
  isPublished Boolean  @default(false)
  authorId    String?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isPublished])
}

model SystemMetric {
  id          String   @id @default(uuid())
  metric      String
  value       Float
  tags        String?  // JSON
  recordedAt  DateTime @default(now())

  @@index([metric, recordedAt])
}

model ApiLog {
  id          String   @id @default(uuid())
  method      String
  path        String
  statusCode  Int
  durationMs  Int
  ipAddress   String?
  userAgent   String?
  userId      String?
  errorMessage String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([statusCode])
}

model ErrorLog {
  id          String   @id @default(uuid())
  level       String   // ERROR, WARN, INFO
  message     String
  stack       String?
  context     String?  // JSON
  userId      String?
  createdAt   DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model BackupRecord {
  id          String   @id @default(uuid())
  filename    String
  sizeBytes   Int
  type        String   // FULL, INCREMENTAL
  status      String   @default("COMPLETED") // RUNNING, COMPLETED, FAILED
  triggeredBy String?
  notes       String?
  createdAt   DateTime @default(now())
}

model AdminNote {
  id          String   @id @default(uuid())
  targetType  String   // USER, PARTNER, REPORT, KYC, WITHDRAWAL
  targetId    String
  authorId    String
  content     String
  isInternal  Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String
  action      String
  entityType  String?
  entityId    String?
  metadata    String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CommissionRule {
  id          String   @id @default(uuid())
  name        String
  type        String   // PERCENTAGE, FIXED
  value       Float
  appliesTo   String   // WALKS, CARRYBUDDY, REFERRAL, ALL
  minAmount   Float?
  maxAmount   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RewardRule {
  id          String   @id @default(uuid())
  name        String
  trigger     String   // SIGNUP, FIRST_WALK, REFERRAL, KYC_COMPLETE
  rewardType  String   // WALLET_CREDIT, BADGE, POINTS
  rewardValue Float
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SosIncident {
  id          String   @id @default(uuid())
  userId      String
  latitude    Float?
  longitude   Float?
  address     String?
  message     String?
  severity    String   @default("HIGH") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("ACTIVE") // ACTIVE, RESPONDING, RESOLVED, FALSE_ALARM
  respondedBy String?
  respondedAt DateTime?
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model ChatReport {
  id          String   @id @default(uuid())
  reporterId  String
  messageId   String?
  conversationId String?
  reason      String
  description String?
  status      String   @default("PENDING") // PENDING, REVIEWED, ACTIONED, DISMISSED
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
}

model BlocklistEntry {
  id          String   @id @default(uuid())
  type        String   // EMAIL, PHONE, IP, DEVICE, USER_ID
  value       String
  reason      String?
  addedBy     String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([type, value])
}

model MaintenanceWindow {
  id          String   @id @default(uuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  affectedServices String  // JSON array
  isActive    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
}

model AppVersion {
  id          String   @id @default(uuid())
  platform    String   // ANDROID, IOS, WEB
  version     String
  buildNumber Int
  isForceUpdate Boolean @default(false)
  releaseNotes String?
  isActive    Boolean  @default(true)
  releasedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}
